
#!/bin/bash
echo "Creating Makefile..."
cat > Makefile << 'EOF'
CC       = gcc
CFLAGS   = -Wall -g
PREFIX   ?= /usr/local
TARBALL  = hello-1.0.tar.gz
DIR      = hello-1.0

all: hello

hello: main.c
	$(CC) $(CFLAGS) -o $@ $^

test_hello: test_main.c
	$(CC) $(CFLAGS) -o $@ $^

check: test_hello
	./test_hello

# 关键修正：先将文件复制到临时目录，再打包
dist:
	mkdir -p $(DIR)
	cp configure main.c test_main.c $(DIR)/
	tar czf $(TARBALL) $(DIR)
	rm -rf $(DIR)

# distcheck 现在可以正确进入目录执行构建
distcheck: dist
	@echo "Running distcheck..."
	tar xzf $(TARBALL)
	cd $(DIR) && ./configure && make && make check
	rm -rf $(DIR)
	@echo "distcheck passed successfully"

install: hello
	install -d $(DESTDIR)$(PREFIX)/bin
	install -m 755 hello $(DESTDIR)$(PREFIX)/bin

clean:
	rm -f hello test_hello $(TARBALL)

.PHONY: all check dist distcheck install clean
EOF

echo "Configuration complete. Now you can run 'make'."
