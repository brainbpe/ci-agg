#!/bin/bash
# 简单的 configure 脚本
echo "Creating Makefile..."
cat > Makefile << 'EOF'
CC       = gcc
CFLAGS   = -Wall -g
PREFIX   ?= /usr/local

all: hello

hello: main.c
	$(CC) $(CFLAGS) -o $@ $^

test_hello: test_main.c
	$(CC) $(CFLAGS) -o $@ $^

check: test_hello
	./test_hello

dist:
	tar czf hello-1.0.tar.gz configure main.c test_main.c

distcheck: dist
	@echo "Running distcheck..."
	tar xzf hello-1.0.tar.gz
	cd hello-1.0 && ./configure && make && make check
	@echo "distcheck passed"

install: hello
	install -d $(DESTDIR)$(PREFIX)/bin
	install -m 755 hello $(DESTDIR)$(PREFIX)/bin

clean:
	rm -f hello test_hello

.PHONY: all check dist distcheck install clean
EOF

echo "Configuration complete. Now you can run 'make'."
